# Database
# SQLite (default - no config needed):
#   DATABASE_URL=sqlite+aiosqlite:///./content_engine.db
# Local Docker Postgres (docker compose up -d):
#   DATABASE_URL=postgresql+asyncpg://aiagency:localdev123@localhost:5432/aiagency
# AWS RDS Postgres (credentials from Secrets Manager):
#   DATABASE_URL=postgresql+asyncpg://user:pass@your-rds-endpoint:5432/aiagency
DATABASE_URL=sqlite+aiosqlite:///./content_engine.db

# Set to true when connecting through PgBouncer (e.g. Supabase pooler)
# PGBOUNCER=false

# Groq
GROQ_API_KEY=gsk_your-key

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI (for vision/style extraction)
# OPENAI_API_KEY=sk-your-key

# Replicate (for FLUX image generation - optional for MVP)
REPLICATE_API_TOKEN=r8_your-token

# Google Drive
# GOOGLE_CREDENTIALS_PATH=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Notion
# NOTION_TOKEN=
# NOTION_PAGE_ID=
